# =============================================================================
# BACKEND ENVIRONMENT VARIABLES
# =============================================================================

# Supabase (required by backend)
SUPABASE_URL=https://your-project.supabase.co

# ⚠️  SERVICE ROLE KEY — full database access, bypasses Row Level Security.
#     Backend only. NEVER put this in frontend .env or commit to git.
#     Rotate at: Supabase Dashboard → Settings → API → service_role key
SUPABASE_KEY=your-supabase-service-role-key

# News collection
GNEWS_API_KEY=your-gnews-api-key
NEWS_FETCH_INTERVAL_MINUTES=15
NEWS_FETCH_ENABLED=true
GNEWS_MAX_ARTICLES=20
RSS_MAX_ARTICLES_PER_FEED=25

# Backend settings
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Groq AI analysis
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
ANALYSIS_BATCH_SIZE=5

# AI chat
CHAT_MAX_CONTEXT_EVENTS=5
CHAT_MAX_CONTEXT_CHARS=6000
CHAT_DEFAULT_USER_ID=
ENABLE_CHAT_DYNAMIC_FETCH=true

# Admin access (V-02) — your Supabase user UUID
ADMIN_USER_IDS=

# =============================================================================
# FRONTEND ENVIRONMENT VARIABLES  (prefix: VITE_)
# Safe to expose — these use the ANON key, not the service role key.
# =============================================================================

# ✅ ANON key only — this is safe for frontend use (restricted by RLS policies)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

VITE_API_BASE_URL=http://localhost:8000
VITE_PUBLIC_APP_URL=http://localhost:5173
