# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-api-key

# News collection
GNEWS_API_KEY=your-gnews-api-key
NEWS_FETCH_INTERVAL_MINUTES=15
NEWS_FETCH_ENABLED=true
GNEWS_MAX_ARTICLES=20
RSS_MAX_ARTICLES_PER_FEED=25

# Backend
DEBUG=true
CORS_ORIGINS=http://localhost:5173

# Groq AI analysis
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
ANALYSIS_BATCH_SIZE=5

# AI chat (optional — required to persist chat_history)
CHAT_MAX_CONTEXT_EVENTS=5
CHAT_MAX_CONTEXT_CHARS=6000
CHAT_DEFAULT_USER_ID=

# Frontend (planned)
VITE_API_BASE_URL=http://localhost:8000
