# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-api-key

# Application
DEBUG=true
CORS_ORIGINS=http://localhost:5173
API_PREFIX=/api

# News collection
GNEWS_API_KEY=your-gnews-api-key
NEWS_FETCH_INTERVAL_MINUTES=15
NEWS_FETCH_ENABLED=true
GNEWS_MAX_ARTICLES=20
RSS_MAX_ARTICLES_PER_FEED=25

# Groq AI analysis
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
ANALYSIS_BATCH_SIZE=5

# AI chat
CHAT_MAX_CONTEXT_EVENTS=5
CHAT_MAX_CONTEXT_CHARS=6000
CHAT_DEFAULT_USER_ID=
# Set false in production to prevent chat queries from triggering paid external API calls (V-10)
ENABLE_CHAT_DYNAMIC_FETCH=true

# Admin access control (V-02)
# Comma-separated Supabase user UUIDs that can trigger news fetch and AI analysis runs.
# Find your UUID: Supabase Dashboard → Authentication → Users → copy the user UUID.
# Leave blank to disable all admin routes (fail-safe).
ADMIN_USER_IDS=
